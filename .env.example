# ─────────────────────────────────────────────────────────────────────────────
# Mikes CRM — Environment Variables
# Copy this file to .env for local dev
# On Render: add each variable under Environment → Add Env Var
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT secret ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ── Google Gemini API (free — no credit card needed) ──────────────────────────
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Email sending via Zoho Mail ───────────────────────────────────────────────
# Set up free at: https://zoho.com/mail
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=587
SMTP_USER=enquiry@mikes-constructions.co.uk
SMTP_PASS=your_zoho_mailbox_password
FROM_EMAIL=enquiry@mikes-constructions.co.uk
FROM_NAME=Mikes Constructions

# ── Notification email ────────────────────────────────────────────────────────
# Who receives internal "new enquiry" alerts
NOTIFY_EMAIL=enquiry@mikes-constructions.co.uk

# ── Calendly integration ──────────────────────────────────────────────────────
# Booking link shown in auto-reply emails to customers
CALENDAR_URL=https://calendly.com/duoride89/free-site-visit

# Personal access token — syncs bookings to CRM every 30 min (free plan)
# Get at: https://calendly.com/integrations/api_webhooks → Personal access tokens
CALENDLY_TOKEN=your_calendly_personal_access_token

# ── CRM Users (initial passwords — set once, users change after first login) ──
# These are only used the FIRST TIME the server starts to create the users.
# After that, passwords are stored hashed in the database.
# Changing these env vars later has NO effect — use the CRM password change feature.
#
# Roles:
#   admin — can manage users and reset passwords
#   staff — can manage enquiries only
#
# admin = you (the developer)
ADMIN_PASSWORD=change_this_now

# mike = the client (admin role)
MIKE_PASSWORD=change_this_now

# blessing = staff
BLESSING_PASSWORD=change_this_now

# mo = staff
MO_PASSWORD=change_this_now

# ── Database path (Render persistent disk) ────────────────────────────────────
# On Render: set to /var/data/enquiries.db
# Locally: leave blank or use ./enquiries.db
DB_PATH=/var/data/enquiries.db

# ── CRM URL (used in internal notification emails) ────────────────────────────
# Set this after you deploy the frontend to Vercel
CRM_URL=https://mikes-crm.vercel.app

# ── Port (Render sets this automatically — don't change) ─────────────────────
PORT=3001
